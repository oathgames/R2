{
  "name": "merlin-desktop",
  "version": "0.7.1",
  "description": "Merlin — Your AI CMO",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.merlin.desktop",
    "productName": "Merlin",
    "asar": true,
    "files": [
      "app/**/*"
    ],
    "extraResources": [
      {
        "from": ".claude",
        "to": "../.claude",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "../assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "CLAUDE.md",
        "to": "../CLAUDE.md"
      },
      {
        "from": "memory.md",
        "to": "../memory.md"
      },
      {
        "from": "version.json",
        "to": "../version.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "app/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "app/icon-1024.png",
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "artifactName": "Merlin.Setup.${version}.${ext}",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Merlin",
      "menuCategory": "Merlin",
      "runAfterFinish": true,
      "installerIcon": "app/icon.ico",
      "uninstallerIcon": "app/icon.ico",
      "installerHeader": "app/icon.ico",
      "license": "LICENSE.txt"
    }
  }
}