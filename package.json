{
  "name": "Merlin",
  "version": "0.8.6",
  "description": "Merlin — Your AI CMO",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.merlin.desktop",
    "productName": "Merlin",
    "asar": true,
    "afterSign": "build/notarize.js",
    "files": [
      "app/**/*"
    ],
    "extraResources": [
      {
        "from": ".claude",
        "to": ".claude",
        "filter": [
          "**/*",
          "!tools/ffmpeg*",
          "!tools/ffprobe*",
          "!tools/Merlin.exe",
          "!tools/Merlin",
          "!tools/merlin-config.json",
          "!tools/.merlin-*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*",
          "!brands/*",
          "brands/example/**/*",
          "!music/*.mp3",
          "!music/*.wav"
        ]
      },
      {
        "from": "CLAUDE.md",
        "to": "CLAUDE.md"
      },
      {
        "from": "memory.md",
        "to": "memory.md"
      },
      {
        "from": "version.json",
        "to": "version.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "app/icon-1024.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "app/icon-1024.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "include": "build/installer.nsh",
      "artifactName": "Merlin.Setup.${version}.${ext}",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Merlin",
      "runAfterFinish": false,
      "menuCategory": false,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "app/icon.ico",
      "uninstallerIcon": "app/icon.ico",
      "installerHeaderIcon": "app/icon.ico"
    }
  }
}
